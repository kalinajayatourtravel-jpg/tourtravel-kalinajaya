# Backend Configuration

# Server
PORT=5000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=tourtravel_kalinajaya
DB_PORT=3306

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_12345678
JWT_EXPIRE=7d

# Email Configuration (untuk notifikasi)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=kalinajayatourtravel@gmail.com
EMAIL_PASSWORD=your_app_password_here
EMAIL_FROM=Kalinajaya Tour Travel <kalinajayatourtravel@gmail.com>

# Midtrans Payment Gateway
MIDTRANS_SERVER_KEY=your_midtrans_server_key_here
MIDTRANS_CLIENT_KEY=your_midtrans_client_key_here
MIDTRANS_ENV=sandbox

# Frontend URL
FRONTEND_URL=http://localhost:3000

# Admin Email
ADMIN_EMAIL=admin@kalinajaya.com

# Company Info
COMPANY_NAME=Kalinajaya Tour Travel
COMPANY_PHONE=+62-XXX-XXXX-XXXX
COMPANY_ADDRESS=Kalinajaya Group, Indonesia
